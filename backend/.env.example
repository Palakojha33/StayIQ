# StayIQ Backend Configuration

# Host and Port for local running or Render/Railway standalone mode
HOST=0.0.0.0
PORT=8000

# Standalone mode flag. Set to "1" to enable loading heavy ML model weights (e.g., DistilBERT)
# Set to "0" (or leave blank) when deploying to Vercel to bypass heavy model loading.
STANDALONE_MODE=0

# CORS origins (comma-separated). Set to * or specific domains (e.g., http://localhost:5173)
CORS_ORIGINS=*

# Directory where trained model artifacts (.pkl, .joblib) are stored
MODEL_DIR=app/models
